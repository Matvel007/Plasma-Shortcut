#!/bin/bash

lang="${LANG:-en_US}"

case "$lang" in
    ru_RU*|uk_UA*|be_BY*)
        shortcut_prefix="Ярлык для"
        comment_prefix="Ярлык для"
        ;;
    *)
        shortcut_prefix="Shortcut to"
        comment_prefix="Shortcut to"
        ;;
esac

for filepath in "$@"; do
    if [ ! -e "$filepath" ]; then
        continue
    fi

    dir=$(dirname "$filepath")
    filename=$(basename "$filepath")
    name="${filename%.*}"
    ext="${filename##*.}"

    shortcut_name="$shortcut_prefix $filename.desktop"
    shortcut_path="$dir/$shortcut_name"

    ext_lower=$(echo "$ext" | tr '[:upper:]' '[:lower:]')

    if [ "$ext_lower" = "exe" ]; then
        SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
        DIALOG="$SCRIPT_DIR/dolphin-shortcut-dialog.py"
        if [ ! -f "$DIALOG" ]; then
            DIALOG="$(dirname "$SCRIPT_DIR")/share/create-shortcut/dolphin-shortcut-dialog.py"
        fi
        if command -v python3 &>/dev/null && [ -f "$DIALOG" ]; then
            python3 "$DIALOG" "$filepath"
        fi
    elif [ -d "$filepath" ]; then
        icon="folder"
        cat > "$shortcut_path" << EOF
[Desktop Entry]
Type=Link
URL=file://$filepath
Icon=$icon
Name=$name
Comment=$comment_prefix $filename
EOF
    else
        case "$ext_lower" in
            png|jpg|jpeg|gif|bmp|webp|svg|tiff|ico)
                cat > "$shortcut_path" << EOF
[Desktop Entry]
Type=Link
URL=file://$filepath
Icon=$filepath
Name=$name
Comment=$comment_prefix $filename
EOF
                ;;
            *)
                cat > "$shortcut_path" << EOF
[Desktop Entry]
Type=Link
URL=file://$filepath
Name=$name
Comment=$comment_prefix $filename
EOF
                ;;
        esac
    fi

done
