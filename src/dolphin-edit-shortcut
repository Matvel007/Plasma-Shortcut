#!/bin/bash

for shortcut_path in "$@"; do
    if [ ! -f "$shortcut_path" ]; then
        continue
    fi

    exe_path=$(grep '^Exec=' "$shortcut_path" | head -1 | sed 's/^Exec=//')

    if echo "$exe_path" | grep -q '^env '; then
        exe_path=$(echo "$exe_path" | grep -oP 'run "\K[^"]+')
    elif echo "$exe_path" | grep -q '^wine '; then
        exe_path=$(echo "$exe_path" | grep -oP 'wine "\K[^"]+')
    fi

    if [ -z "$exe_path" ] || [ ! -f "$exe_path" ]; then
        continue
    fi

    SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
    DIALOG="$SCRIPT_DIR/dolphin-shortcut-dialog.py"
    if [ ! -f "$DIALOG" ]; then
        DIALOG="$(dirname "$SCRIPT_DIR")/share/create-shortcut/dolphin-shortcut-dialog.py"
    fi

    if command -v python3 &>/dev/null && [ -f "$DIALOG" ]; then
        python3 "$DIALOG" "$exe_path" "$shortcut_path"
    fi
done
